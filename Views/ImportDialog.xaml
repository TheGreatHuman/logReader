<Window x:Class="LogVision.Views.ImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LogVision.Models"
        Title="导入日志包"
        Height="520" Width="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundDarkBrush}"
        Foreground="{DynamicResource ForegroundPrimaryBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="导入日志包" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"
                   Foreground="{DynamicResource ForegroundPrimaryBrush}"/>

        <!-- Metadata -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="日志名称" Margin="0,0,0,4" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtLogName" Margin="0,0,0,10"/>

            <TextBlock Text="描述 (可选)" Margin="0,0,0,4" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtDescription" Height="50" AcceptsReturn="True"
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
        </StackPanel>

        <!-- CSV File List -->
        <GroupBox Grid.Row="2" Margin="0,4,0,8"
                  BorderBrush="{DynamicResource BorderBrush}"
                  Foreground="{DynamicResource ForegroundPrimaryBrush}">
            <GroupBox.Header>
                <TextBlock Text="选择要导入的数据文件" FontWeight="SemiBold"/>
            </GroupBox.Header>
            <ListView x:Name="FileListView" 
                      Background="{DynamicResource BackgroundMediumBrush}"
                      Foreground="{DynamicResource ForegroundPrimaryBrush}"
                      BorderThickness="0">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="40">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="文件名" Width="200"
                                        DisplayMemberBinding="{Binding FileName}" />
                        <GridViewColumn Header="行数" Width="80"
                                        DisplayMemberBinding="{Binding RowCount}" />
                        <GridViewColumn Header="列数" Width="60"
                                        DisplayMemberBinding="{Binding ColumnNames.Count}" />
                        <GridViewColumn Header="类型" Width="120">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox SelectedValue="{Binding FileType}"
                                              SelectedValuePath="Tag"
                                              Background="{DynamicResource BackgroundLightBrush}"
                                              Foreground="{DynamicResource ForegroundPrimaryBrush}"
                                              Width="100">
                                        <ComboBoxItem Content="运行数据" Tag="{x:Static local:CsvFileType.RunData}"/>
                                        <ComboBoxItem Content="操作事件" Tag="{x:Static local:CsvFileType.OpEvent}"/>
                                    </ComboBox>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>

        <!-- Summary -->
        <TextBlock Grid.Row="3" x:Name="TxtSummary" Margin="0,0,0,8"
                   Foreground="{DynamicResource ForegroundSecondaryBrush}"/>

        <!-- Progress -->
        <ProgressBar Grid.Row="4" x:Name="ImportProgress" Height="4" Margin="0,0,0,12"
                     Visibility="Collapsed"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="确认导入" Width="100" Style="{StaticResource AccentButton}" Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
