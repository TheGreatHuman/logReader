<Window x:Class="LogVision.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        xmlns:converters="clr-namespace:LogVision.Converters"
        mc:Ignorable="d"
        Title="LogVision - 日志可视化分析平台"
        Height="750" Width="1280"
        MinHeight="500" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <converters:ThemeModeConverter x:Key="ThemeModeConverter"/>
        <converters:TimestampToDateConverter x:Key="TimestampToDateConverter"/>
        <converters:CountToVisibilityConverter x:Key="CountToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Toolbar -->
        <Border Grid.Row="0" Background="{DynamicResource BackgroundMediumBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="8,6">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="LogVision" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center" Margin="4,0,16,0"/>

                    <Button Command="{Binding ImportZipCommand}"
                            ToolTip="导入日志压缩包" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="导入 ZIP" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding RefreshColumnsCommand}"
                            ToolTip="刷新当前图表显示">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="刷新图表" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Theme Switcher + Column Selection (right side) -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                            HorizontalAlignment="Right">
                    <TextBlock Text="主题:" VerticalAlignment="Center" Margin="0,0,4,0"
                               Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                    <ComboBox SelectedIndex="{Binding ThemeMode, Converter={StaticResource ThemeModeConverter}}"
                              ToolTip="切换主题" Width="90" VerticalAlignment="Center" Margin="0,0,16,0">
                        <ComboBoxItem Content="深色"/>
                        <ComboBoxItem Content="浅色"/>
                        <ComboBoxItem Content="跟随系统"/>
                    </ComboBox>

                    <ToggleButton x:Name="ColumnConfigToggle" Margin="0,0,0,0" Padding="8,4"
                                  ToolTip="配置显示的数据列"
                                  Click="ColumnConfigToggle_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="列配置" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>
                    <Popup x:Name="ColumnConfigPopup"
                           PlacementTarget="{Binding ElementName=ColumnConfigToggle}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           Closed="ColumnConfigPopup_Closed">
                        <Border Background="{DynamicResource BackgroundMediumBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="8" Margin="4"
                                MinWidth="200" MaxHeight="400">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" Opacity="0.3" ShadowDepth="3"/>
                            </Border.Effect>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="选择显示的数据列"
                                           FontWeight="SemiBold" FontSize="13"
                                           Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                           Margin="4,2,4,8"/>
                                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                            HorizontalAlignment="Right" Margin="4,8,4,2">
                                    <Button Content="全选" Click="ColumnSelectAll_Click"
                                            Padding="8,3" Margin="0,0,6,0" FontSize="11"/>
                                    <Button Content="全不选" Click="ColumnSelectNone_Click"
                                            Padding="8,3" FontSize="11"/>
                                </StackPanel>
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              MaxHeight="300">
                                    <ItemsControl ItemsSource="{Binding AvailableColumns}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding}" Margin="4,3" FontSize="12"
                                                          Click="ColumnCheckBox_Click"
                                                          Loaded="ColumnCheckBox_Loaded"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Popup>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content: Three Panels -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="150" MaxWidth="400"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="300" MinWidth="150" MaxWidth="500"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="350" MinWidth="200" MaxWidth="600"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Log Package List -->
            <Border Grid.Column="0" Background="{DynamicResource BackgroundMediumBrush}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="日志列表"
                               FontWeight="SemiBold" FontSize="14"
                               Margin="12,10,12,6"
                               Foreground="{DynamicResource ForegroundSecondaryBrush}"/>

                    <Button DockPanel.Dock="Bottom" Content="删除选中"
                            Command="{Binding DeleteSelectedPackageCommand}"
                            Margin="8,4,8,8" Padding="8,4"
                            FontSize="11"/>

                    <ListBox ItemsSource="{Binding LogPackages}"
                             SelectedItem="{Binding SelectedLogPackage}"
                             Margin="4">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4,4">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                               FontSize="13" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock FontSize="11"
                                               Foreground="{DynamicResource ForegroundSecondaryBrush}">
                                        <Run Text="{Binding OriginalFileName, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="10"
                                               Foreground="{DynamicResource ForegroundSecondaryBrush}">
                                        <Run Text="{Binding ImportDate, StringFormat='{}{0:yyyy-MM-dd HH:mm}', Mode=OneWay}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding ColumnNames.Count, Mode=OneWay}"/>
                                        <Run Text=" 列"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Description}" FontSize="10"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                               Visibility="{Binding Description, 
                                                   Converter={StaticResource BoolToVis},
                                                   FallbackValue=Collapsed}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Left Splitter -->
            <GridSplitter Grid.Column="1" Width="3" ResizeBehavior="PreviousAndNext"/>

            <!-- Center Panel: Chart + Timeline -->
            <Border Grid.Column="2" Background="{DynamicResource BackgroundDarkBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Empty state -->
                    <TextBlock Grid.Row="0"
                               Text="导入日志包或从左侧列表选择一个日志包以开始分析"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="14" Foreground="{DynamicResource ForegroundSecondaryBrush}"
                               Visibility="{Binding SelectedLogPackage, 
                                   Converter={StaticResource InverseBoolToVis},
                                   FallbackValue=Visible}"/>

                    <!-- ScottPlot Chart -->
                    <scottplot:WpfPlot x:Name="WpfPlot1"
                                       Grid.Row="0"
                                       Margin="0"
                                       MouseDown="WpfPlot1_MouseDown"/>

                    <!-- Operation Timeline -->
                    <Border x:Name="TimelineBorder" Grid.Row="1"
                            Height="50"
                            Background="{DynamicResource BackgroundMediumBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Visibility="{Binding OperationEvents.Count,
                                Converter={StaticResource CountToVis}}">
                        <Grid>
                            <Line X1="0" Y1="25"
                                  X2="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
                                  Y2="25"
                                  Stroke="{DynamicResource BorderBrush}"
                                  StrokeThickness="1"/>
                            <Canvas x:Name="TimelineCanvas" ClipToBounds="True"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Right Splitter -->
            <GridSplitter Grid.Column="3" Width="3" ResizeBehavior="PreviousAndNext"/>

            <!-- Right Panel: Data Table -->
            <Border Grid.Column="4" Background="{DynamicResource BackgroundMediumBrush}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="数据详情"
                               FontWeight="SemiBold" FontSize="14"
                               Margin="12,10,12,6"
                               Foreground="{DynamicResource ForegroundSecondaryBrush}"/>

                    <DataGrid x:Name="DataGridView"
                              ItemsSource="{Binding TableData}"
                              SelectedItem="{Binding SelectedTableRow}"
                              AutoGenerateColumns="True"
                              IsReadOnly="True"
                              CanUserResizeRows="False"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              SelectionChanged="DataGridView_SelectionChanged"
                              Margin="4"/>
                </DockPanel>
            </Border>

            <!-- Right Splitter 2 -->
            <GridSplitter Grid.Column="5" Width="3" ResizeBehavior="PreviousAndNext"/>

            <!-- Operation Log Panel -->
            <Border Grid.Column="6" Background="{DynamicResource BackgroundMediumBrush}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="操作日志"
                               FontWeight="SemiBold" FontSize="14"
                               Margin="12,10,12,6"
                               Foreground="{DynamicResource ForegroundSecondaryBrush}"/>

                    <DataGrid x:Name="OperationLogGrid"
                              ItemsSource="{Binding OperationEvents}"
                              SelectedItem="{Binding SelectedOperationEvent}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserResizeRows="False"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              EnableRowVirtualization="True"
                              SelectionChanged="OperationLogGrid_SelectionChanged"
                              Margin="4">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="时间" Width="140"
                                Binding="{Binding FormattedTime}"/>
                            <DataGridTextColumn Header="用户" Width="80"
                                Binding="{Binding User}"/>
                            <DataGridTextColumn Header="来源" Width="70"
                                Binding="{Binding Source}"/>
                            <DataGridTextColumn Header="操作" Width="100"
                                Binding="{Binding Result}"/>
                            <DataGridTextColumn Header="描述" Width="*"
                                Binding="{Binding Description}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Bottom Status Bar -->
        <Border Grid.Row="2" Background="{DynamicResource BackgroundMediumBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="8,4">
            <DockPanel>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           Foreground="{DynamicResource ForegroundSecondaryBrush}"
                           FontSize="12"/>
                <ProgressBar DockPanel.Dock="Right" Width="150"
                             Value="{Binding ProgressValue}" Maximum="100"
                             HorizontalAlignment="Right"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
